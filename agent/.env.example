# LiveKit (same as backend)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI (for STT, LLM, TTS)
OPENAI_API_KEY=

# Backend API base URL (for RAG search)
BACKEND_URL=http://localhost:3000

# Optional: use local STT/TTS models instead of OpenAI plugin
USE_LOCAL_STT=1
USE_LOCAL_TTS=1
LOCAL_WHISPER_MODEL=base
PIPER_MODEL_PATH=./en_US-lessac-medium.onnx
